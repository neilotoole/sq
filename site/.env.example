#####################################
#         Version: 1.0              #
#####################################
#                                   #
#      MANUAL INPUT REQUIRED        #
#                                   #
#####################################
#
# Copy to .env (gitignored) and fill in values:
#   cp .env.example .env
#
# Same variables as GitHub Actions secrets for Site Publish (dispatch).
# Never commit .env.

# Netlify user settings → Applications → Personal access tokens → New access
# token. Enable deploy access for the sq.io site (your Netlify team/site).
# https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_AUTH_TOKEN=

# Netlify dashboard → sq.io site → Site configuration → General → Site ID
# (UUID, not the site URL slug). Or: cd site && bun x netlify-cli link && status
NETLIFY_SITE_ID=
